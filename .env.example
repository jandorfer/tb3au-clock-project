# ---- Daily joke mode (required only if you use the joke/cron job) ----
OPENAI_API_KEY=sk-...
API_NINJAS_KEY=...

# ---- MQTT push from Home Assistant (tb3au_mqtt.py) ----
# Hostname of the Mosquitto broker. On a Pi that is NOT the HA host, use the
# HA machine's LAN IP (e.g. 192.168.1.50). On HAOS the broker container is
# reachable from another container as:
MQTT_BROKER=core-mosquitto
MQTT_PORT=1883
# Create this user in Home Assistant (Settings -> People -> Add User) and give
# it access to Mosquitto. Do NOT reuse the API keys above.
MQTT_USER=tb3au
MQTT_PASSWORD=
# Optional; auto-generated if omitted.
# MQTT_CLIENT_ID=tb3au-epd
